# Database
DATABASE_URL="postgresql://username:password@localhost:5432/enterprise_admin"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Password Hashing
HASH_ROUNDS=12

# OTP Configuration
OTP_ENABLED=false
OTP_EXPIRY_MINUTES=10

# SMS Configuration (for OTP)
SMS_PROVIDER="twilio" # twilio, aws-sns
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Email Configuration
EMAIL_PROVIDER="smtp" # smtp, aws-ses
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# AWS Configuration (for S3, SES, etc.)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_DOMAIN=""

# Redis Configuration (for caching and queues)
REDIS_URL="redis://localhost:6379"

# Application Settings
NODE_ENV="development"
LOG_LEVEL="info"

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# File Upload
MAX_FILE_SIZE=10485760 # 10MB
ALLOWED_FILE_TYPES="pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif"

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *" # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Monitoring
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# Feature Flags
FEATURE_PAYROLL_ENABLED=true
FEATURE_INVENTORY_ENABLED=true
FEATURE_PROCUREMENT_ENABLED=true
FEATURE_ACCOUNTING_ENABLED=true
FEATURE_WORKFLOWS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_REPORTING_ENABLED=true