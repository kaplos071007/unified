# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterprise_admin"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="development-secret-key-change-in-production"

# Password Hashing
HASH_ROUNDS=12

# OTP Configuration
OTP_ENABLED=false
OTP_EXPIRY_MINUTES=10

# Application Settings
NODE_ENV="development"
LOG_LEVEL="info"

# Redis Configuration (for caching and queues)
REDIS_URL="redis://localhost:6379"

# AWS S3 Configuration (optional)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Feature Flags
FEATURE_PAYROLL_ENABLED=true
FEATURE_INVENTORY_ENABLED=true
FEATURE_PROCUREMENT_ENABLED=true
FEATURE_ACCOUNTING_ENABLED=true
FEATURE_WORKFLOW_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_REPORTING_ENABLED=true
FEATURE_DOCUMENT_MANAGEMENT_ENABLED=true

# Email Configuration (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@enterprise.com"

# SMS Configuration (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# File Upload Configuration
MAX_FILE_SIZE="10MB"
ALLOWED_FILE_TYPES="jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx"
UPLOAD_DIR="uploads"

# Security
SESSION_MAX_AGE=86400
PASSWORD_MIN_LENGTH=8
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Development
DEBUG=false
API_BASE_URL="http://localhost:3000/api"