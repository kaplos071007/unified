# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/enterprise_admin"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="development-secret-key-change-in-production"

# Password Hashing
HASH_ROUNDS=12

# OTP Configuration
OTP_ENABLED=false
OTP_EXPIRY_MINUTES=10

# Application Settings
NODE_ENV="development"
LOG_LEVEL="info"

# Redis Configuration (for caching and queues)
REDIS_URL="redis://localhost:6379"

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif"

# Feature Flags
FEATURE_PAYROLL_ENABLED=true
FEATURE_INVENTORY_ENABLED=true
FEATURE_PROCUREMENT_ENABLED=true
FEATURE_ACCOUNTING_ENABLED=true
FEATURE_WORKFLOWS_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_REPORTING_ENABLED=true